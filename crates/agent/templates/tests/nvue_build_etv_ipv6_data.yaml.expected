- header:
    model: VX
    nvue-api-version: nvue_v1
    rev-id: 1.0
    version: Cumulus Linux 5.6.0
- set:
    bridge:
      domain:
        br_default:
          vlan:
            '100':
              vni:
                '1000': {}
    evpn:
      enable: on
    interface:
      lo:
        ip:
          address:
            10.0.0.1/32: {}
        type: loopback
      p0_if:
        type: swp
      pf0vf0_if:
        type: swp
        bridge:
          domain:
            br_default:
              access: 100
        acl:
          p0000_deny_prefixes_ipv4:
            inbound: {}
          drop_dhcp_flood_over_overlay:
            inbound: {}
          p0009_vpc_peer_egress_from_host:
            inbound: {}
          p0009_vpc_peer_ingress_to_host:
            outbound: {}
          p0010_vpc_isolation_ipv4:
            inbound: {}
      vlan100:
        type: svi
        vlan: 100
        ip:
          address:
            10.0.1.1/24: {}
    nve:
      vxlan:
        arp-nd-suppress: on
        enable: on
        source:
          address: 10.0.0.1
    router:
      bgp:
        autonomous-system: 65000
        enable: on
        router-id: 10.0.0.1
      policy:
        prefix-list:
          FORGE_FROM_UNDERLAY:
            rule:
              '10':
                action: permit
                match:
                  0.0.0.0/0: {}
              '1000':
                action: deny
                match:
                  any: {}
          dpu_from_instance:
            rule:
              '65535':
                action: deny
                match:
                  any: {}
        route-map:
          FORGE_TO_UNDERLAY:
            rule:
              '10':
                action:
                  deny: {}
                match:
                  interface: vlan100
              '1000':
                action:
                  permit: {}
          dpu_to_instance:
            rule:
              '10':
                action:
                  deny: {}
    vrf:
      default:
        router:
          nexthop-tracking:
            ipv4:
              resolved-via-default: on
          static:
            10.0.1.0/24:
              address-family: ipv4-unicast
              via:
                vlan100:
                  type: interface
          bgp:
            address-family:
              ipv4-unicast:
                network:
                  10.0.0.1/32: {}
                  10.0.1.0/24: {}
                enable: on
                multipaths:
                  ebgp: 128
                redistribute:
                  connected:
                    enable: on
              l2vpn-evpn:
                enable: on
            enable: on
            neighbor:
              p0_if:
                peer-group: underlay
                type: unnumbered
              10.0.1.2:
                passive-mode: on
                peer-group: tenant
                type: numbered
            path-selection:
              multipath:
                aspath-ignore: on
            peer-group:
              routeserver:
                address-family:
                  ipv4-unicast:
                    enable: off
                  l2vpn-evpn:
                    aspath:
                      allow-my-asn:
                        enable: on
                    enable: on
                multihop-ttl: 255
                remote-as: external
                update-source: lo
              tenant:
                address-family:
                  ipv4-unicast:
                    policy:
                      inbound:
                        prefix-list: dpu_from_instance
                      outbound:
                        route-map: dpu_to_instance
                nexthop-connected-check: off
                remote-as: 65100
                timers:
                  connection-retry: 10
                  hold: 9
                  keepalive: 3
                  route-advertisement: none
              underlay:
                remote-as: external
                address-family:
                  ipv4-unicast:
                    policy:
                      inbound:
                        prefix-list: FORGE_FROM_UNDERLAY
                      outbound:
                        route-map: FORGE_TO_UNDERLAY
                    aspath:
                      allow-my-asn:
                        enable: on
                  l2vpn-evpn:
                    aspath:
                      allow-my-asn:
                        enable: on
                    enable: on
    acl:
      p0000_deny_prefixes_ipv4:
        type: ipv4
        rule:
          '10':
            action:
              permit: {}
            match:
              ip:
                dest-ip: 10.0.1.0/24
          '1002':
            action:
              deny: {}
            match:
              ip:
                dest-ip: 192.0.2.0/24
      p0010_vpc_isolation_ipv4:
        type: ipv4
        rule:
          '10':
            action:
              permit: {}
            match:
              ip:
                dest-ip: 10.0.1.0/24
          '1000':
            action:
              deny: {}
            match:
              ip:
                dest-ip: 10.0.0.0/16
      p0009_vpc_peer_egress_from_host:
        type: ipv4
        rule:
          '1':
            action:
              permit: {}
            match:
              ip:
                dest-ip: 10.0.2.0/24
      p0009_vpc_peer_ingress_to_host:
        type: ipv4
        rule:
          '1':
            action:
              permit: {}
            match:
              ip:
                source-ip: 10.0.2.0/24
      drop_dhcp_flood_over_overlay:
        rule:
          '10':
            action:
              deny: {}
            hw-offload: off
            match:
              ip:
                dest-ip: 255.255.255.255
                protocol: udp
                dest-port:
                  '67': {}
                source-port:
                  '68': {}
        type: ipv4
